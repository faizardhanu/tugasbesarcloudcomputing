# ─── Database ─────────────────────────────────────────────────
# Lokal (tanpa Docker): DB_HOST=localhost
# Docker              : DB_HOST=db
DB_HOST=db
DB_USER=root
DB_PASSWORD=hotel123
DB_NAME=hotel_u

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=rahasialoh

# ─── Express Server Port ──────────────────────────────────────
PORT=5000

# ─── URL API untuk Frontend (Next.js) ────────────────────────
# Lokal: http://localhost:5000/api
# Docker (via Nginx): http://localhost/api
# GCP (production): http://IP_ATAU_DOMAIN_GCP/api
NEXT_PUBLIC_API_URL=/api
