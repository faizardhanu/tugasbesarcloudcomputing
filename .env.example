# ─── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=hotel_u

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here

# ─── Express Server Port ──────────────────────────────────────
PORT=5000

# ─── URL API untuk Frontend (Next.js) ────────────────────────
# Lokal: http://localhost:5000/api
# Docker (via Nginx): http://localhost/api
# GCP (production): http://IP_ATAU_DOMAIN_GCP/api
NEXT_PUBLIC_API_URL=http://localhost/api
